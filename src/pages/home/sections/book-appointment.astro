---
import { BOOKING_CONTENT } from '../../../data/booking-data';

const bookingStatus = Astro.url.searchParams.get('booking');
---

<section id="book-appointment" class="booking-section" aria-labelledby="booking-title">
  <div class="container">
    <div class="header-content">
      <h2 id="booking-title" class="section-title">{BOOKING_CONTENT.title}</h2>
      <p class="section-subtitle">{BOOKING_CONTENT.subtitle}</p>
    </div>

    {
      bookingStatus === 'success' && (
        <div class="form-alert form-alert-success" role="status" aria-live="polite">
          Thanks! We received your request. We’ll call you within 24 hours to confirm.
        </div>
      )
    }
    {
      bookingStatus === 'error' && (
        <div class="form-alert form-alert-error" role="alert">
          Something went wrong. Please check the form and try again.
        </div>
      )
    }

    <form class="booking-form" action="/api/appointments" method="POST">
      <input class="hp-field" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="form-row two-col">
        <div class="form-group">
          <label for="name">{BOOKING_CONTENT.form.nameLabel}</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="pet">{BOOKING_CONTENT.form.petLabel}</label>
          <input type="text" id="pet" name="pet" required />
        </div>
      </div>

      <div class="form-row two-col">
        <div class="form-group">
          <label for="phone">Contact number*</label>
          <input type="tel" id="phone" name="phone" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="service">{BOOKING_CONTENT.form.serviceLabel}</label>
        <input type="text" id="service" name="service" required />
      </div>

      <div class="form-group">
        <label class="branch-main-label">{BOOKING_CONTENT.form.branchLabel}</label>
        <div class="checkbox-group">
          {BOOKING_CONTENT.form.branchOptions.map((option) => (
            <div class="checkbox-item">
              <input type="radio" id={option.id} name="branch" value={option.value} required />
              <label for={option.id}>{option.label}</label>
            </div>
          ))}
        </div>
      </div>

      <div class="form-group half-width">
        <label for="datetime">{BOOKING_CONTENT.form.datetimeLabel}</label>
        <input type="datetime-local" id="datetime" name="datetime" required />
      </div>

      <button type="submit" class="submit-btn">Submit Request</button>
    </form>
  </div>
</section>

<style>
  :root {
    --booking-bg: #bb9313;
    --booking-text-white: #ffffff;
    --booking-title-stroke: #0a441e;
  }

  .booking-section {
    background-color: var(--booking-bg);
    padding: 5rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    color: var(--booking-text-white);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .header-content {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin: 0 0 1rem 0;
    color: var(--booking-text-white);
    text-shadow:
      -3px -3px 0 var(--booking-title-stroke),
      3px -3px 0 var(--booking-title-stroke),
      -3px 3px 0 var(--booking-title-stroke),
      3px 3px 0 var(--booking-title-stroke),
      0 5px 10px rgba(0, 0, 0, 0.2);
  }

  .section-subtitle {
    font-size: 1.2rem;
    line-height: 1.5;
    margin: 0;
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 700px) {
    .form-row.two-col {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-alert {
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem 0;
    font-weight: 700;
    line-height: 1.4;
  }

  .form-alert-success {
    background: rgba(255, 255, 255, 0.18);
    border: 2px solid rgba(255, 255, 255, 0.55);
  }

  .form-alert-error {
    background: rgba(10, 68, 30, 0.22);
    border: 2px solid rgba(10, 68, 30, 0.55);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .form-group.half-width {
    width: 100%;
    max-width: 320px;
  }

  .booking-form label {
    font-size: 1rem;
    font-weight: 700;
  }

  .booking-form input[type="text"],
  .booking-form input[type="email"],
  .booking-form input[type="tel"],
  .booking-form input[type="datetime-local"] {
    width: 100%;
    height: 44px;
    background-color: var(--booking-text-white);
    border: none;
    border-radius: 8px;
    padding: 0 1rem;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    color: #333;
    outline: none;
  }

  .booking-form input:focus {
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.5);
  }

  .branch-main-label {
    margin-bottom: 0.25rem;
  }

  .checkbox-group {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .checkbox-item input[type="radio"] {
    width: 22px;
    height: 22px;
    accent-color: var(--booking-title-stroke);
    cursor: pointer;
  }

  .checkbox-item label {
    font-size: 1.1rem;
    font-weight: 500;
    cursor: pointer;
  }

  .submit-btn {
    margin-top: 0.5rem;
    align-self: flex-start;
    background-color: var(--booking-title-stroke);
    color: var(--booking-text-white);
    border: none;
    padding: 1rem 2rem;
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'Montserrat', sans-serif;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
  }

  .submit-btn:hover {
    background-color: #062a18;
    transform: translateY(-1px);
  }

  @media (max-width: 600px) {
    .section-subtitle {
      font-size: 1.05rem;
    }

    .form-group.half-width {
      max-width: none;
    }
  }

  @media (max-width: 400px) {
    .checkbox-group {
      gap: 1rem;
    }
  }
</style>
