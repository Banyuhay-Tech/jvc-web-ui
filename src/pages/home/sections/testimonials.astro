---
import { TESTIMONIALS_CONTENT } from '../../../data/testimonials-data';
---

<section class="testimonials-section" aria-labelledby="testimonials-title">
  <div class="container">
    <div class="content-wrapper">
      <!-- Left Column: Text & Decorative Images -->
      <div class="left-column">
        <h2 id="testimonials-title" class="section-title">
          {TESTIMONIALS_CONTENT.header.title}
        </h2>
        <p class="section-description">
          {TESTIMONIALS_CONTENT.header.description}
        </p>
      </div>

      <!-- Right Column: Testimonial Carousel -->
      <div class="right-column">
        <div class="testimonial-carousel">
          <button type="button" class="testimonial-arrow testimonial-arrow-left" aria-label="Previous testimonial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>

          <div class="testimonial-track">
            <div class="testimonial-inner" style="transform: translateX(-400%);">
              {TESTIMONIALS_CONTENT.reviews.map((review) => (
                <div class="testimonial-card">
                  <p class="review-text">{review.text}</p>
                  <p class="review-author">{review.author}</p>
                </div>
              ))}
            </div>
          </div>

          <button type="button" class="testimonial-arrow testimonial-arrow-right" aria-label="Next testimonial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>

        <!-- Carousel Indicators -->
        <div class="carousel-indicators" id="testimonial-dots" role="tablist">
          {TESTIMONIALS_CONTENT.reviews.map((_, i) => (
            <button type="button" class={`dot ${i === 4 ? 'active' : ''}`} role="tab" aria-label={`Testimonial ${i + 1}`} aria-selected={i === 4} data-index={i}></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-bg-dark-green: #0a441e;
    --color-text-white: #ffffff;
    --color-card-yellow: #bb9313;
    --color-text-black: #000000;
    --color-dot-inactive: #ede4c5;
  }

  .testimonials-section {
    background-image: url('/images/testimonial-bg.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 5rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    color: var(--color-text-white);
    overflow: hidden;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media (min-width: 800px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 3rem;
    }
  }

  /* LEFT COLUMN */
  .left-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.3;
    margin: 0 0 1.5rem 0;
    white-space: pre-line;
  }

  .section-description {
    font-size: 1.1rem;
    line-height: 1.75;
    margin: 0 0 3rem 0;
    max-width: 450px;
    text-align: justify;
  }

  /* RIGHT COLUMN */
  .right-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .testimonial-carousel {
    position: relative;
    width: 100%;
    max-width: 550px;
  }

  .testimonial-track {
    overflow: hidden;
    border-radius: 32px;
  }

  .testimonial-inner {
    display: flex;
    transition: transform 0.3s ease;
  }

  .testimonial-inner .testimonial-card {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .testimonial-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-text-white);
    color: var(--color-card-yellow);
    border: none;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .testimonial-arrow:hover {
    opacity: 0.9;
    transform: translateY(-50%) scale(1.05);
  }

  .testimonial-arrow svg {
    width: 20px;
    height: 20px;
  }

  .testimonial-arrow-left {
    left: -20px;
  }

  .testimonial-arrow-right {
    right: -20px;
  }

  .testimonial-card {
    background-color: var(--color-card-yellow);
    color: var(--color-text-black);
    padding: 3rem 2.5rem;
    border-radius: 32px;
    width: 100%;
    max-width: 550px;
    font-family: 'Montserrat', sans-serif;
    box-sizing: border-box;
  }

  .review-text {
    font-size: 1.1rem;
    line-height: 1.65;
    margin: 0 0 2rem 0;
    white-space: pre-line;
    text-align: justify;
  }

  .review-author {
    font-size: 1.2rem;
    font-weight: bold;
    text-align: right;
    margin: 0;
    text-decoration: underline;
  }

  .carousel-indicators {
    display: flex;
    gap: 12px;
    margin-top: 2rem;
    justify-content: center;
  }

  .carousel-indicators .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--color-dot-inactive);
    border: none;
    cursor: pointer;
    transition: background-color 0.2s;
    padding: 0;
  }

  .carousel-indicators .dot[aria-selected="true"],
  .carousel-indicators .dot.active {
    background-color: var(--color-text-white);
  }

  @media (max-width: 799px) {
    .testimonial-card {
      padding: 2rem 1.5rem;
    }

    .testimonial-arrow-left {
      left: -8px;
    }

    .testimonial-arrow-right {
      right: -8px;
    }
  }
</style>

<script>
  (function () {
    const inner = document.querySelector('.testimonial-inner') as HTMLElement | null;
    const cards = document.querySelectorAll('.testimonial-inner .testimonial-card');
    const prevBtn = document.querySelector('.testimonial-arrow-left');
    const nextBtn = document.querySelector('.testimonial-arrow-right');
    const dots = document.querySelectorAll('#testimonial-dots .dot');

    if (!inner || cards.length === 0) return;

    let index = 4;

    function updateCarousel() {
      if (inner) inner.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
        dot.classList.toggle('active', i === index);
      });
    }

    prevBtn?.addEventListener('click', () => {
      index = (index - 1 + cards.length) % cards.length;
      updateCarousel();
    });

    nextBtn?.addEventListener('click', () => {
      index = (index + 1) % cards.length;
      updateCarousel();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        index = i;
        updateCarousel();
      });
    });
  })();
</script>
