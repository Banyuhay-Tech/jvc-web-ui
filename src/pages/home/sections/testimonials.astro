---
import { TESTIMONIALS_CONTENT } from '../../../data/testimonials-data';
const reviews = TESTIMONIALS_CONTENT.reviews;
// Cyclic reviews for infinite loop logic
const cyclicReviews = [reviews[reviews.length - 1], ...reviews, reviews[0]];
---

<section class="testimonials-section">
  <div class="container">
    <div class="main-layout">
      <div class="left-content">
        <div class="text-group">
          <h2 class="section-title">{TESTIMONIALS_CONTENT.header.title}</h2>
          <p class="section-description">{TESTIMONIALS_CONTENT.header.description}</p>
        </div>

      </div>

      <div class="right-carousel">
        <div class="glass-outer-box">
          <span class="quote-mark" aria-hidden="true">“</span>

          <div class="carousel-clip" role="region" aria-label="Testimonials carousel">
            <div class="testimonial-inner" id="track" style="transform: translateX(-100%);">
              {cyclicReviews.map((review) => (
                <div class="testimonial-slide">
                  <div class="testimonial-card">
                    <p class="review-body">“{review.text}”</p>
                    <div class="author-area">
                      <span class="line"></span>
                      <p class="author-name">{review.author}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="nav-bar">
            <button type="button" class="arrow prev" data-action="prev" aria-label="Previous">‹</button>
            <div class="dots" id="testimonial-dots" role="tablist" aria-label="Testimonials">
              {reviews.map((_, i) => (
                <button type="button" class={`dot ${i === 0 ? 'active' : ''}`} data-index={i} role="tab" aria-label={`Go to slide ${i + 1}`} aria-selected={i === 0}></button>
              ))}
            </div>
            <button type="button" class="arrow next" data-action="next" aria-label="Next">›</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --brand-green: #0a441e;
    --brand-gold: #bb9313;
    --brand-cream: #ede4c5;
  }

  .testimonials-section {
    background: var(--brand-green) url('/images/testimonial-bg.png') center/cover no-repeat;
    padding: 4rem 1rem;
    overflow: hidden; /* Critical for carousels */
    min-height: 600px;
    display: flex;
    align-items: center;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* DESKTOP LAYOUT (Matches your screenshot) */
  .main-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .main-layout {
      grid-template-columns: 35% 65%; /* Precise balance */
    }
  }

  /* LEFT SIDE */
  .left-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    color: white;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .section-description {
    color: #cbd5e1;
    font-family: 'Montserrat', sans-serif;
    line-height: 1.6;
    max-width: 320px;
  }

  /* RIGHT SIDE - THE CAROUSEL */
  .right-carousel {
    min-width: 0; /* allow grid item to shrink; prevents overflow */
    width: 100%;
    position: relative;
  }

  .glass-outer-box {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 40px;
    padding: 3rem;
    position: relative;
  }

  .quote-mark {
    position: absolute;
    top: 10px;
    left: 40px;
    font-size: 6rem;
    color: var(--brand-gold);
    font-family: 'Calistoga', serif;
    opacity: 0.4;
  }

  .carousel-clip {
    overflow: hidden; /* Keeps the cards from bleeding off screen */
    width: 100%;
  }

  .testimonial-inner {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .testimonial-slide {
    flex: 0 0 100%;
    min-width: 100%;
    padding: 0.5rem;
    box-sizing: border-box; /* padding should not increase slide width */
  }

  .testimonial-card {
    background: var(--brand-gold);
    color: #1a1a1a;
    padding: 2.5rem;
    border-radius: 24px;
    min-height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .review-body {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .author-area {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .line { width: 30px; height: 2px; background: rgba(0,0,0,0.2); }
  .author-name { font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin: 0; }

  /* NAVIGATION */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .nav-bar { justify-content: flex-start; }
  }

  .arrow {
    background: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.5rem;
    display: grid;
    place-items: center;
    color: var(--brand-green);
    transition: 0.3s;
  }

  .arrow:hover { background: var(--brand-gold); color: white; }

  .dots { display: flex; gap: 8px; }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.3);
    transition: 0.3s;
    padding: 0;
    cursor: pointer;
  }
  .dot.active {
    background: var(--brand-gold);
    width: 24px;
    border-radius: 4px;
  }

  /* MOBILE RESPONSIVENESS */
  @media (max-width: 1023px) {
    .left-content { align-items: center; text-align: center; }
    .section-description { max-width: 100%; }
    .glass-outer-box { padding: 2rem 1rem; }
  }
</style>

<script>
  (function () {
    const SWIPE_THRESHOLD = 50;

    const clip = document.querySelector('.carousel-clip');
    const inner = document.getElementById('track');
    const slides = document.querySelectorAll('#track .testimonial-slide');
    const dots = document.querySelectorAll('#testimonial-dots .dot');
    const arrows = document.querySelectorAll('.nav-bar .arrow');

    if (!(clip instanceof HTMLElement)) return;
    if (!(inner instanceof HTMLElement)) return;
    if (!slides || slides.length === 0) return;

    const clipEl = /** @type {HTMLElement} */ (clip);
    const innerEl = /** @type {HTMLElement} */ (inner);

    const totalSlides = slides.length;
    const realCount = totalSlides - 2;
    let index = 1;
    let startX = 0;
    let isJumping = false;

    function getRealIndex() {
      if (index === 0) return realCount - 1;
      if (index === totalSlides - 1) return 0;
      return index - 1;
    }

    function updateDots() {
      const r = getRealIndex();
      dots.forEach((dot, i) => {
        if (!(dot instanceof HTMLElement)) return;
        dot.setAttribute('aria-selected', i === r ? 'true' : 'false');
        dot.classList.toggle('active', i === r);
      });
    }

    function applyTransform(useTransition: boolean) {
      innerEl.style.transition = useTransition ? 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)' : 'none';
      innerEl.style.transform = `translateX(-${index * 100}%)`;
    }

    function jumpIfNeeded() {
      if (index === totalSlides - 1) {
        index = 1;
        applyTransform(false);
      } else if (index === 0) {
        index = totalSlides - 2;
        applyTransform(false);
      }
      innerEl.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    }

    function goTo(slideIndex: number) {
      if (isJumping) return;
      index = slideIndex;
      applyTransform(true);
      updateDots();
    }

    function next() {
      if (isJumping) return;
      index = index + 1;
      applyTransform(true);
      updateDots();
    }

    function prev() {
      if (isJumping) return;
      index = index - 1;
      applyTransform(true);
      updateDots();
    }

    innerEl.addEventListener('transitionend', () => {
      if (isJumping) return;
      isJumping = true;
      jumpIfNeeded();
      updateDots();
      requestAnimationFrame(() => { isJumping = false; });
    });

    function handleSwipeEnd(clientX: number) {
      const diff = clientX - startX;
      if (diff > SWIPE_THRESHOLD) prev();
      else if (diff < -SWIPE_THRESHOLD) next();
    }

    clipEl.addEventListener('touchstart', (e) => {
      const t = e.touches && e.touches[0];
      if (!t) return;
      startX = t.clientX;
    }, { passive: true });

    clipEl.addEventListener('touchend', (e) => {
      const t = e.changedTouches && e.changedTouches[0];
      if (!t) return;
      handleSwipeEnd(t.clientX);
    }, { passive: true });

    clipEl.addEventListener('mousedown', (e) => {
      if (e.button !== 0) return;
      startX = e.clientX;
    });

    clipEl.addEventListener('mouseup', (e) => {
      if (e.button !== 0) return;
      handleSwipeEnd(e.clientX);
    });

    dots.forEach((dot, i) => {
      if (!(dot instanceof HTMLElement)) return;
      dot.addEventListener('click', () => goTo(i + 1));
    });

    arrows.forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        if (action === 'prev') prev();
        else next();
      });
    });

    updateDots();
  })();
</script>
