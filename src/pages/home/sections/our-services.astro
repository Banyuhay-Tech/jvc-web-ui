---
import { SERVICES_CONTENT } from '../../../data/our-services-data';
import { ServiceCardIcon } from '../../../components/ui/ServiceCardIcon';
---

<section class="services-section" aria-labelledby="services-title">
  <div class="container">
    <h2 id="services-title" class="section-title">{SERVICES_CONTENT.title}</h2>

    <div class="branches-grid">
      {SERVICES_CONTENT.branches.map((branch) => (
        <div class="branch-column">
          <!-- Branch Header -->
          <div class="branch-header">
            <h3 class="branch-name">{branch.name}</h3>
            <p class="branch-address">{branch.address}</p>
          </div>

          <!-- Service Cards Carousel -->
          <div class="carousel-wrapper">
            <button type="button" class="nav-arrow left-arrow" aria-label="Previous service">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>

            <div class="carousel-track">
              <div class="carousel-inner">
                {branch.services.map((service) => (
                  <div class="service-card">
                    <div class="card-content">
                      <div class="icon-wrapper">
                        <ServiceCardIcon name={service.iconName} size={88} />
                      </div>
                      <h4 class="service-title">{service.title}</h4>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <button type="button" class="nav-arrow right-arrow" aria-label="Next service">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-bg-cream: #ede4c5;
    --color-card-beige: #ddd2b0;
    --color-text-green: #0a441e;
    --color-text-gold: #bb9313;
    --color-arrow-bg: #c9bf9e;
  }

  .services-section {
    background-color: var(--color-bg-cream);
    padding: 5rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-text-green);
    text-align: center;
    margin: 0 0 4rem 0;
    line-height: 1.3;
  }

  .branches-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .branches-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }

  .branch-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .branch-header {
    text-align: center;
    margin-bottom: 2rem;
    min-height: 80px;
  }

  .branch-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text-gold);
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .branch-address {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-text-gold);
    margin: 0;
    line-height: 1.6;
    white-space: pre-line;
    text-align: center;
  }

  .carousel-wrapper {
    position: relative;
    width: 320px;
    margin: 0 auto;
  }

  .carousel-track {
    overflow: hidden;
    border-radius: 24px;
    height: 280px;
  }

  .carousel-inner {
    display: flex;
    transition: transform 0.3s ease;
  }

  .carousel-inner .service-card {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .service-card {
    font-family: 'Montserrat', sans-serif;
    background-color: var(--color-card-beige);
    border-radius: 24px;
    padding: 3rem 2rem;
    height: 280px;
    min-height: 280px;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    box-sizing: border-box;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .icon-wrapper {
    width: 88px;
    height: 88px;
    color: var(--color-text-green);
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text-green);
    margin: 0;
    line-height: 1.35;
    white-space: normal;
  }

  .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-arrow-bg);
    color: var(--color-text-green);
    border: none;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
    z-index: 2;
  }

  .nav-arrow:hover {
    background-color: #a07d0f;
    transform: translateY(-50%) scale(1.1);
  }

  .nav-arrow svg {
    width: 18px;
    height: 18px;
  }

  .left-arrow {
    left: -18px;
  }

  .right-arrow {
    right: -18px;
  }

  @media (max-width: 400px) {
    .left-arrow {
      left: -10px;
    }
    .right-arrow {
      right: -10px;
    }
  }
</style>

<script>
  document.querySelectorAll('.branch-column').forEach((column) => {
    const inner = column.querySelector('.carousel-inner') as HTMLElement | null;
    const cards = column.querySelectorAll('.carousel-inner .service-card');
    const prevBtn = column.querySelector('.left-arrow');
    const nextBtn = column.querySelector('.right-arrow');

    if (!inner || cards.length === 0 || !prevBtn || !nextBtn) return;

    let index = 0;

    function updateCarousel() {
      (inner as HTMLElement).style.transform = `translateX(-${index * 100}%)`;
    }

    prevBtn.addEventListener('click', () => {
      index = (index - 1 + cards.length) % cards.length;
      updateCarousel();
    });

    nextBtn.addEventListener('click', () => {
      index = (index + 1) % cards.length;
      updateCarousel();
    });
  });
</script>
