---
import { SERVICES_CONTENT } from '../../../data/our-services-data';
import { ServiceCardIcon } from '../../../components/ui/ServiceCardIcon';
---

<section id="our-services" class="services-section" aria-labelledby="services-title">
  <div class="container">
    <div class="header-group">
      <h2 id="services-title" class="section-title">{SERVICES_CONTENT.title}</h2>
      <div class="title-underline"></div>
    </div>

    <div class="branches-grid">
      {SERVICES_CONTENT.branches.map((branch) => {
        const services = branch.services;
        return (
        <div class="branch-column">
          <header class="branch-header">
            <h3 class="branch-name">{branch.name}</h3>
            <p class="branch-address">{branch.address}</p>
          </header>

          <!-- Service Cards Carousel -->
          <div class="carousel-wrapper">
            <div class="carousel-track" role="region" aria-label="Service cards carousel">
              <div class="carousel-inner">
                {services.map((service, i) => (
                  <div class="service-card" data-index={i}>
                    <div class="card-content">
                      <div class="icon-wrapper">
                        <ServiceCardIcon name={service.iconName} size={64} />
                      </div>
                      <h4 class="service-title">{service.title}</h4>
                      <div class="card-accent"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="services-dots" role="tablist">
              {services.map((_, i) => (
                <button
                  type="button"
                  class={`dot ${i === 0 ? 'active' : ''}`}
                  role="tab"
                  aria-selected={i === 0}
                  data-index={i}
                />
              ))}
            </div>
          </div>
        </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  :root {
    --color-bg-cream: #f9f7f0;
    --color-text-green: #0a441e;
    --color-text-gold: #b38e11;
    --transition-elegant: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .services-section {
    background-color: var(--color-bg-cream);
    padding: 8rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .header-group {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-text-green);
    margin: 0;
    font-weight: 400;
  }

  .title-underline {
    width: 60px;
    height: 2px;
    background: var(--color-text-gold);
    margin: 1.5rem auto 0;
  }

  .branches-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6rem;
  }

  @media (min-width: 850px) {
    .branches-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  .branch-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .branch-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .branch-name {
    font-family: 'Calistoga', serif;
    font-size: 1.75rem;
    color: var(--color-text-green);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .branch-address {
    font-size: 0.9rem;
    color: var(--color-text-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.8;
  }

  .carousel-wrapper {
    position: relative;
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }

  .carousel-track {
    overflow: hidden;
    border-radius: 18px;
    height: 320px;
  }

  .carousel-inner {
    display: flex;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-inner .service-card {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .service-card {
    font-family: 'Montserrat', sans-serif;
    background: #ffffff;
    padding: 2.25rem 1.75rem;
    height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid rgba(187, 147, 19, 0.1);
    border-radius: 22px;
    box-shadow: 0 10px 40px -15px rgba(10, 68, 30, 0.1);
    transition: var(--transition-elegant);
    position: relative;
    overflow: hidden;
  }

  .service-card:hover {
    border-color: var(--color-text-gold);
    box-shadow: 0 16px 46px -18px rgba(10, 68, 30, 0.18);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .icon-wrapper {
    color: var(--color-text-gold);
    transition: var(--transition-elegant);
  }

  .service-card:hover .icon-wrapper {
    transform: scale(1.1);
    color: var(--color-text-green);
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-title {
    font-family: 'Calistoga', serif;
    font-size: 1.6rem;
    color: var(--color-text-green);
    font-weight: 400;
  }

  .card-accent {
    width: 30px;
    height: 1px;
    background: var(--color-text-gold);
    transition: var(--transition-elegant);
  }

  .service-card:hover .card-accent {
    width: 60px;
  }

  .services-dots {
    display: flex;
    gap: 12px;
    margin-top: 2rem;
    justify-content: center;
    align-items: center;
  }

  .dot {
    width: 8px;
    height: 8px;
    border: 1px solid var(--color-text-gold);
    border-radius: 50%;
    background: transparent;
    transition: var(--transition-elegant);
    padding: 0;
    cursor: pointer;
  }

  .dot.active,
  .dot[aria-selected="true"] {
    background: var(--color-text-gold);
    transform: scale(1.2);
  }
</style>

<script>
  document.querySelectorAll('.branch-column').forEach((column) => {
    const inner = column.querySelector('.carousel-inner') as HTMLElement | null;
    const cards = column.querySelectorAll('.carousel-inner .service-card');
    const dots = column.querySelectorAll('.services-dots .dot') as NodeListOf<HTMLButtonElement>;

    if (!inner || cards.length === 0) return;

    const count = cards.length;
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      current = ((index % count) + count) % count;
      inner.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
        dot.setAttribute('aria-selected', i === current ? 'true' : 'false');
      });
    }

    function next() {
      goTo(current + 1);
    }

    function startAuto() {
      if (autoTimer) return;
      autoTimer = setInterval(() => {
        if (!document.hidden) next();
      }, 3000);
    }

    function stopAuto() {
      if (!autoTimer) return;
      clearInterval(autoTimer);
      autoTimer = null;
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        stopAuto();
        goTo(Number(dot.dataset.index ?? 0));
        startAuto();
      });
    });

    const wrapper = column.querySelector('.carousel-wrapper') as HTMLElement;
    if (wrapper) {
      wrapper.addEventListener('mouseenter', stopAuto);
      wrapper.addEventListener('mouseleave', startAuto);
      wrapper.addEventListener('touchstart', stopAuto, { passive: true });
      wrapper.addEventListener('touchend', startAuto, { passive: true });
    }

    let touchStartX = 0;
    inner.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    inner.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        stopAuto();
        goTo(diff > 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    goTo(0);
    startAuto();
  });
</script>
