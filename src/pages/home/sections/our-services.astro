---
import { SERVICES_CONTENT } from '../../../data/our-services-data';
import { ServiceCardIcon } from '../../../components/ui/ServiceCardIcon';
---

<section id="our-services" class="services-section" aria-labelledby="services-title">
  <div class="container">
    <div class="header-group">
      <h2 id="services-title" class="section-title">{SERVICES_CONTENT.title}</h2>
      <div class="title-underline"></div>
    </div>

    <div class="branches-grid">
      {SERVICES_CONTENT.branches.map((branch) => {
        const services = branch.services;
        const duplicatedServices = [...services, ...services];
        return (
        <div class="branch-column">
          <header class="branch-header">
            <h3 class="branch-name">{branch.name}</h3>
            <p class="branch-address">{branch.address}</p>
          </header>

          <!-- Service Cards Carousel (infinite scroll) -->
          <div class="carousel-wrapper">
            <div class="carousel-track" role="region" aria-label="Service cards carousel" tabindex="0">
              <div class="carousel-inner" style={`width: ${duplicatedServices.length * 100}%; --card-count: ${duplicatedServices.length}`}>
                {duplicatedServices.map((service, i) => (
                  <div class="service-card" data-index={i}>
                    <div class="card-content">
                      <div class="icon-wrapper">
                        <ServiceCardIcon name={service.iconName} size={64} />
                      </div>
                      <h4 class="service-title">{service.title}</h4>
                      <div class="card-accent"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="services-dots" role="tablist">
              {services.map((_, i) => (
                <button
                  type="button"
                  class={`dot ${i === 0 ? 'active' : ''}`}
                  role="tab"
                  aria-selected={i === 0}
                  data-index={i}
                />
              ))}
            </div>
          </div>
        </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  :root {
    --color-bg-cream: #f9f7f0;
    --color-text-green: #0a441e;
    --color-text-gold: #b38e11;
    --transition-elegant: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .services-section {
    background-color: var(--color-bg-cream);
    padding: 8rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .header-group {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-text-green);
    margin: 0;
    font-weight: 400;
  }

  .title-underline {
    width: 60px;
    height: 2px;
    background: var(--color-text-gold);
    margin: 1.5rem auto 0;
  }

  .branches-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6rem;
  }

  @media (min-width: 850px) {
    .branches-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  .branch-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .branch-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .branch-name {
    font-family: 'Calistoga', serif;
    font-size: 1.75rem;
    color: var(--color-text-green);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .branch-address {
    font-size: 0.9rem;
    color: var(--color-text-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.8;
  }

  .carousel-wrapper {
    position: relative;
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }

  .carousel-track {
    overflow-x: auto;
    overflow-y: hidden;
    border-radius: 18px;
    height: 320px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-inner {
    display: flex;
    height: 100%;
  }

  .carousel-inner .service-card {
    flex: 0 0 calc(100% / var(--card-count, 16));
    min-width: calc(100% / var(--card-count, 16));
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .service-card {
    font-family: 'Montserrat', sans-serif;
    background: #ffffff;
    padding: 2.25rem 1.75rem;
    height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid rgba(187, 147, 19, 0.1);
    border-radius: 22px;
    box-shadow: 0 10px 40px -15px rgba(10, 68, 30, 0.1);
    transition: var(--transition-elegant);
    position: relative;
    overflow: hidden;
  }

  .service-card:hover {
    border-color: var(--color-text-gold);
    box-shadow: 0 16px 46px -18px rgba(10, 68, 30, 0.18);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .icon-wrapper {
    color: var(--color-text-gold);
    transition: var(--transition-elegant);
  }

  .service-card:hover .icon-wrapper {
    transform: scale(1.1);
    color: var(--color-text-green);
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-title {
    font-family: 'Calistoga', serif;
    font-size: 1.6rem;
    color: var(--color-text-green);
    font-weight: 400;
  }

  .carousel-track {
    touch-action: pan-x pan-y pinch-zoom;
  }

  .card-accent {
    width: 30px;
    height: 1px;
    background: var(--color-text-gold);
    transition: var(--transition-elegant);
  }

  .service-card:hover .card-accent {
    width: 60px;
  }

  .services-dots {
    display: flex;
    gap: 12px;
    margin-top: 2rem;
    justify-content: center;
    align-items: center;
  }

  .dot {
    width: 8px;
    height: 8px;
    border: 1px solid var(--color-text-gold);
    border-radius: 50%;
    background: transparent;
    transition: var(--transition-elegant);
    padding: 0;
    cursor: pointer;
  }

  .dot.active,
  .dot[aria-selected="true"] {
    background: var(--color-text-gold);
    transform: scale(1.2);
  }
</style>

<script>
  document.querySelectorAll('.branch-column').forEach((column) => {
    const trackEl = column.querySelector('.carousel-track') as HTMLElement | null;
    const inner = column.querySelector('.carousel-inner') as HTMLElement | null;
    const cards = column.querySelectorAll('.carousel-inner .service-card');
    const dots = column.querySelectorAll('.services-dots .dot') as NodeListOf<HTMLButtonElement>;

    if (!trackEl || !inner || cards.length === 0) return;
    const track = trackEl;

    const totalCards = cards.length;
    const realCount = Math.max(1, Math.floor(totalCards / 2));
    let oneSetWidth = 0;
    let ticking = false;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function measure() {
      oneSetWidth = track.scrollWidth / 2;
    }

    function getRealIndexFromScroll() {
      const slideWidth = track.clientWidth || 1;
      const approx = Math.round(track.scrollLeft / slideWidth);
      return ((approx % realCount) + realCount) % realCount;
    }

    function updateDots() {
      if (!dots || dots.length === 0) return;
      const active = getRealIndexFromScroll();
      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === active ? 'true' : 'false');
        dot.classList.toggle('active', i === active);
      });
    }

    function wrapScroll() {
      if (oneSetWidth <= 0) measure();
      const left = track.scrollLeft;
      if (oneSetWidth <= 0) {
        ticking = false;
        return;
      }
      if (left >= oneSetWidth - 2) {
        track.scrollLeft = left - oneSetWidth;
      } else if (left <= 0) {
        track.scrollLeft = left + oneSetWidth;
      }
      updateDots();
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(wrapScroll);
        ticking = true;
      }
    }

    track.addEventListener('scroll', onScroll, { passive: true });

    function onWheel(e: WheelEvent) {
      if (oneSetWidth <= 0) return;
      const left = track.scrollLeft;
      if (left <= 1 && e.deltaX > 0) {
        track.scrollLeft = oneSetWidth;
        e.preventDefault();
      } else if (left >= oneSetWidth - 1 && e.deltaX < 0) {
        track.scrollLeft = left - oneSetWidth;
        e.preventDefault();
      }
    }

    track.addEventListener('wheel', onWheel, { passive: false });

    function goToRealIndex(realIndex: number, behavior: ScrollBehavior = 'smooth') {
      const slideWidth = track.clientWidth || 0;
      const target = Math.max(0, Math.min(realCount - 1, realIndex)) * slideWidth;
      track.scrollTo({ left: target, behavior });
      updateDots();
    }

    function next() {
      const slideWidth = track.clientWidth || 0;
      if (slideWidth <= 0) return;
      // If we're at the seam between the duplicated sets, wrap first
      if (oneSetWidth <= 0) measure();
      if (oneSetWidth > 0) {
        const left = track.scrollLeft;
        if (left >= oneSetWidth - 2) track.scrollLeft = left - oneSetWidth;
        else if (left <= 0) track.scrollLeft = left + oneSetWidth;
      }
      track.scrollBy({ left: slideWidth, behavior: 'smooth' });
    }

    function startAuto() {
      if (autoTimer) return;
      autoTimer = setInterval(() => {
        if (!document.hidden) next();
      }, 3000);
    }

    function stopAuto() {
      if (!autoTimer) return;
      clearInterval(autoTimer);
      autoTimer = null;
    }

    track.addEventListener('mouseenter', stopAuto);
    track.addEventListener('mouseleave', startAuto);
    track.addEventListener('focusin', stopAuto);
    track.addEventListener('focusout', startAuto);
    track.addEventListener('pointerdown', stopAuto, { passive: true });
    track.addEventListener('pointerup', startAuto, { passive: true });
    track.addEventListener('touchstart', stopAuto, { passive: true });
    track.addEventListener('touchend', startAuto, { passive: true });

    dots?.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.index ?? '0');
        stopAuto();
        goToRealIndex(idx, 'smooth');
        startAuto();
      });
    });

    const ro = new ResizeObserver(() => {
      measure();
      updateDots();
    });
    ro.observe(track);
    measure();
    // Avoid starting exactly at 0 (prevents immediate wrap logic jitter)
    if (track.scrollLeft === 0) track.scrollLeft = 1;
    updateDots();
    startAuto();
  });
</script>
