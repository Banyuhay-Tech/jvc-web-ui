---
import { HERO_CONTENT } from '../../../data/home-hero-data';
---

<section class="hero-section">
  <div class="hero-container">
    <div class="content-wrapper">
      <div class="text-column">
        <h1 class="hero-title">{HERO_CONTENT.title}</h1>
        <h2 class="hero-subtitle">{HERO_CONTENT.subtitle}</h2>
        <p class="hero-description">{HERO_CONTENT.description}</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-title-green: #0a441e;
    --color-subtitle-gold: #bb9313;
    --color-text-body: #333333;
  }

  .hero-section {
    position: relative;
    background-image: url('/images/Home.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 4rem 1.5rem;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* LAYOUT */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 800px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
  }

  /* LEFT COLUMN (TEXT) */
  .text-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 650px;
    text-align: left;
    align-items: flex-start;
  }

  .hero-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    color: var(--color-title-green);
    line-height: 1.25;
    margin: 0;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .hero-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-subtitle-gold);
    line-height: 1.45;
    margin: 0.5rem 0 1rem 0;
    text-align: left;
    white-space: pre-line;
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--color-text-body);
    margin: 0;
    max-width: 550px;
    text-align: left;
  }

  @media (max-width: 799px) {
    .text-column {
      text-align: center;
      align-items: center;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
