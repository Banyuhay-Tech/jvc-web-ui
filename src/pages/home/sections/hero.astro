---
import { HERO_CONTENT } from '../../../data/home-hero-data';
---

<section class="hero-section">
  <!-- Decorative Background Paw Prints -->
  <div class="bg-paw paw-1">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 6.5C8.5 7.88071 7.38071 9 6 9C4.61929 9 3.5 7.88071 3.5 6.5C3.5 5.11929 4.61929 4 6 4C7.38071 4 8.5 5.11929 8.5 6.5Z" />
      <path d="M15.5 3.5C15.5 4.88071 14.3807 6 13 6C11.6193 6 10.5 4.88071 10.5 3.5C10.5 2.11929 11.6193 1 13 1C14.3807 1 15.5 2.11929 15.5 3.5Z" />
      <path d="M21 7.5C21 8.88071 19.8807 10 18.5 10C17.1193 10 16 8.88071 16 7.5C16 6.11929 17.1193 5 18.5 5C19.8807 5 21 6.11929 21 7.5Z" />
      <path d="M12.5 23C16.6421 23 20 19.6421 20 15.5C20 12.5 17.5 10 14.5 10C13.5 10 12.5 10.5 12.5 10.5C12.5 10.5 11.5 10 10.5 10C7.5 10 5 12.5 5 15.5C5 19.6421 8.35786 23 12.5 23Z" />
    </svg>
  </div>
  <div class="bg-paw paw-2">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 6.5C8.5 7.88071 7.38071 9 6 9C4.61929 9 3.5 7.88071 3.5 6.5C3.5 5.11929 4.61929 4 6 4C7.38071 4 8.5 5.11929 8.5 6.5Z" />
      <path d="M15.5 3.5C15.5 4.88071 14.3807 6 13 6C11.6193 6 10.5 4.88071 10.5 3.5C10.5 2.11929 11.6193 1 13 1C14.3807 1 15.5 2.11929 15.5 3.5Z" />
      <path d="M21 7.5C21 8.88071 19.8807 10 18.5 10C17.1193 10 16 8.88071 16 7.5C16 6.11929 17.1193 5 18.5 5C19.8807 5 21 6.11929 21 7.5Z" />
      <path d="M12.5 23C16.6421 23 20 19.6421 20 15.5C20 12.5 17.5 10 14.5 10C13.5 10 12.5 10.5 12.5 10.5C12.5 10.5 11.5 10 10.5 10C7.5 10 5 12.5 5 15.5C5 19.6421 8.35786 23 12.5 23Z" />
    </svg>
  </div>

  <div class="hero-container">
    <div class="content-wrapper">
      <!-- Left Column: Text Content -->
      <div class="text-column">
        <h1 class="hero-title">{HERO_CONTENT.title}</h1>
        <h2 class="hero-subtitle">{HERO_CONTENT.subtitle}</h2>
        <p class="hero-description">{HERO_CONTENT.description}</p>
      </div>

      <!-- Right Column: Image Composition -->
      <div class="image-column">
        <div class="image-wrapper">
          <!-- Organic Green Blob Shape -->
          <div class="green-blob"></div>
          <!-- Foreground Pets Image -->
          <img
            src={HERO_CONTENT.image.src}
            alt={HERO_CONTENT.image.alt}
            class="pets-image"
            width="480"
            height="480"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-bg-cream: #efe5d5;
    --color-title-green: #1a432b;
    --color-subtitle-gold: #b8862d;
    --color-text-body: #333333;
    --color-blob-green: #0b4a26;
    --color-paw-print: #e4d8c5;
  }

  .hero-section {
    position: relative;
    background-color: var(--color-bg-cream);
    padding: 4rem 1.5rem;
    overflow: hidden;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* BACKGROUND PAW PRINTS */
  .bg-paw {
    position: absolute;
    color: var(--color-paw-print);
    z-index: 0;
  }

  .bg-paw svg {
    width: 100%;
    height: 100%;
  }

  .paw-1 {
    top: -20px;
    right: 25%;
    width: 180px;
    transform: rotate(15deg);
  }

  .paw-2 {
    bottom: 20%;
    left: 45%;
    width: 140px;
    transform: rotate(-20deg);
  }

  /* LAYOUT */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 800px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
  }

  /* LEFT COLUMN (TEXT) */
  .text-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 650px;
  }

  .hero-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    color: var(--color-title-green);
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: var(--color-subtitle-gold);
    line-height: 1.3;
    margin: 0.5rem 0 1rem 0;
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-body);
    margin: 0;
    max-width: 550px;
  }

  /* RIGHT COLUMN (IMAGE & BLOB) */
  .image-column {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    width: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    max-width: 500px;
    height: 450px;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .green-blob {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 90%;
    height: 85%;
    background-color: var(--color-blob-green);
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    z-index: 1;
  }

  .pets-image {
    position: relative;
    z-index: 2;
    width: 110%;
    height: auto;
    object-fit: contain;
    transform: translateX(5%);
  }

  @media (max-width: 799px) {
    .text-column {
      text-align: center;
      align-items: center;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .image-wrapper {
      height: 350px;
    }
  }
</style>
