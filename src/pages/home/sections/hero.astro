---
import { HERO_CONTENT } from '../../../data/home-hero-data';
---

<section class="hero-section">
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-container">
    <div class="content-wrapper">
      <div class="text-column">
        <h1 class="hero-title">{HERO_CONTENT.title}</h1>
        <h2 class="hero-subtitle">{HERO_CONTENT.subtitle}</h2>
        <p class="hero-description">{HERO_CONTENT.description}</p>

        <div class="hero-actions">
          <a href="#book-appointment" class="btn-primary">Get Started</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --color-title-green: #0a441e;
    --color-subtitle-gold: #bb9313;
    --color-text-body: #333333;
    --color-white: #ffffff;
    --transition-smooth: all 0.3s ease;
  }

  .hero-section {
    position: relative;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
    display: flex;
    align-items: center;
    min-height: 60vh;
    padding: clamp(3.5rem, 7vw, 6rem) 1.25rem;
    background-color: #f4f4f4;
    background-image: url('/images/Home.png');
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.7) 45%,
      rgba(255, 255, 255, 0.55) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .text-column {
    width: 100%;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
    align-items: center;
  }

  .hero-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.25rem, 7vw, 4.5rem);
    font-weight: 800;
    color: var(--color-title-green);
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .hero-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.05rem, 3.3vw, 1.85rem);
    font-weight: 700;
    color: var(--color-subtitle-gold);
    line-height: 1.3;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: pre-line;
  }

  .hero-description {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    line-height: 1.6;
    color: var(--color-text-body);
    margin: 0;
    max-width: 580px;
  }

  .hero-actions {
    margin-top: 0.75rem;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-primary {
    display: inline-block;
    padding: 1rem 2.25rem;
    background-color: var(--color-title-green);
    color: var(--color-white);
    text-decoration: none;
    border-radius: 10px;
    font-weight: 700;
    transition: var(--transition-smooth);
    width: min(100%, 320px);
    text-align: center;
  }

  .btn-primary:hover {
    background-color: var(--color-subtitle-gold);
    transform: translateY(-2px);
  }

  .btn-primary:focus-visible {
    outline: 3px solid rgba(187, 147, 19, 0.55);
    outline-offset: 3px;
  }

  @media (min-width: 800px) {
    .hero-section {
      padding: 8rem 1.5rem;
      background-position: center;
      min-height: 70vh;
    }

    .hero-overlay {
      background: linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.9) 0%,
        rgba(255, 255, 255, 0.4) 100%
      );
    }

    .content-wrapper {
      flex-direction: row;
      justify-content: flex-start;
      align-items: center;
    }

    .text-column {
      text-align: left;
      align-items: flex-start;
      max-width: 650px;
    }

    .hero-actions {
      justify-content: flex-start;
    }
  }
</style>
