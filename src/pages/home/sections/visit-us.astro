---
import { VISIT_US_CONTENT } from '../../../data/visit-us-data';
---

<section id="visit-us" class="visit-us-section" aria-labelledby="visit-us-title">
  <!-- Decorative Background Paw Prints -->
  <div class="bg-paw paw-left" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 6.5C8.5 7.88071 7.38071 9 6 9C4.61929 9 3.5 7.88071 3.5 6.5C3.5 5.11929 4.61929 4 6 4C7.38071 4 8.5 5.11929 8.5 6.5Z" />
      <path d="M15.5 3.5C15.5 4.88071 14.3807 6 13 6C11.6193 6 10.5 4.88071 10.5 3.5C10.5 2.11929 11.6193 1 13 1C14.3807 1 15.5 2.11929 15.5 3.5Z" />
      <path d="M21 7.5C21 8.88071 19.8807 10 18.5 10C17.1193 10 16 8.88071 16 7.5C16 6.11929 17.1193 5 18.5 5C19.8807 5 21 6.11929 21 7.5Z" />
      <path d="M12.5 23C16.6421 23 20 19.6421 20 15.5C20 12.5 17.5 10 14.5 10C13.5 10 12.5 10.5 12.5 10.5C12.5 10.5 11.5 10 10.5 10C7.5 10 5 12.5 5 15.5C5 19.6421 8.35786 23 12.5 23Z" />
    </svg>
  </div>
  <div class="bg-paw paw-right" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 6.5C8.5 7.88071 7.38071 9 6 9C4.61929 9 3.5 7.88071 3.5 6.5C3.5 5.11929 4.61929 4 6 4C7.38071 4 8.5 5.11929 8.5 6.5Z" />
      <path d="M15.5 3.5C15.5 4.88071 14.3807 6 13 6C11.6193 6 10.5 4.88071 10.5 3.5C10.5 2.11929 11.6193 1 13 1C14.3807 1 15.5 2.11929 15.5 3.5Z" />
      <path d="M21 7.5C21 8.88071 19.8807 10 18.5 10C17.1193 10 16 8.88071 16 7.5C16 6.11929 17.1193 5 18.5 5C19.8807 5 21 6.11929 21 7.5Z" />
      <path d="M12.5 23C16.6421 23 20 19.6421 20 15.5C20 12.5 17.5 10 14.5 10C13.5 10 12.5 10.5 12.5 10.5C12.5 10.5 11.5 10 10.5 10C7.5 10 5 12.5 5 15.5C5 19.6421 8.35786 23 12.5 23Z" />
    </svg>
  </div>

  <div class="container">
    <h2 id="visit-us-title" class="section-title">
      {VISIT_US_CONTENT.title}
    </h2>

    <div class="locations-grid" role="list" aria-label="Our locations">
      {VISIT_US_CONTENT.branches.map((branch) => (
        <article class="location-card" role="listitem" aria-label={branch.name}>
          <div class="branch-photo">
            <img
              src={branch.mapImage}
              alt={`${branch.name} location`}
              loading="lazy"
              decoding="async"
              class="branch-photo-img"
              width="800"
              height="450"
            />
          </div>
          <h3 class="branch-name">{branch.name}</h3>
          <p class="branch-detail">{branch.address}</p>
          <p class="branch-detail"><strong>Phone:</strong> {branch.phone}</p>
          <p class="branch-detail"><strong>Hours:</strong> {branch.hours}</p>
          <a
            href={branch.facebookLink}
            target="_blank"
            rel="noopener noreferrer"
            class="facebook-link"
          >
            {branch.facebookText}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-bg-cream: #ede4c5;
    --color-text-green: #0a441e;
    --color-text-gold: #bb9313;
    --color-paw-print: #e0d6b8;
  }

  .visit-us-section {
    position: relative;
    background-color: var(--color-bg-cream);
    padding: 5rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* BACKGROUND PAW PRINTS */
  .bg-paw {
    position: absolute;
    color: var(--color-paw-print);
    z-index: 1;
  }

  .bg-paw svg {
    width: 100%;
    height: 100%;
  }

  .paw-left {
    bottom: -50px;
    left: -80px;
    width: 350px;
    transform: rotate(-25deg);
  }

  .paw-right {
    top: -50px;
    right: -80px;
    width: 300px;
    transform: rotate(15deg);
  }

  /* TITLE */
  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    color: var(--color-text-green);
    text-align: center;
    margin: 0 0 4rem 0;
    line-height: 1.3;
  }

  /* GRID */
  .locations-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 900px) {
    .locations-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.25rem;
    }
  }

  .location-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 0 2rem 2rem 2rem;
    box-shadow: 0 10px 30px rgba(10, 68, 30, 0.08);
    border-left: 5px solid var(--color-text-gold);
    overflow: hidden;
  }

  .branch-photo {
    width: calc(100% + 4rem);
    margin-left: -2rem;
    margin-right: -2rem;
    border-bottom: 1px solid rgba(10, 68, 30, 0.08);
    background: #ffffff;
  }

  .branch-photo-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .branch-name {
    color: var(--color-text-gold);
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: 0.06em;
    margin: 1.5rem 0 0.75rem 0;
    font-size: 1.2rem;
  }

  .branch-detail {
    color: var(--color-text-green);
    line-height: 1.55;
    margin: 0.25rem 0;
    white-space: pre-line;
  }

  .facebook-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 1.05rem;
    font-weight: 900;
    color: var(--color-text-green);
    text-decoration: underline;
    transition: opacity 0.2s;
  }

  .facebook-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .bg-paw {
      display: none;
    }
    .location-card {
      padding: 1.5rem 1.5rem;
    }
  }
</style>
