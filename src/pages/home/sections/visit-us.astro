---
import { VISIT_US_CONTENT } from '../../../data/visit-us-data';
---

<section id="visit-us" class="visit-us-section" aria-labelledby="visit-us-title">
  <div class="bg-paw paw-left" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 6.5C8.5 7.88071 7.38071 9 6 9C4.61929 9 3.5 7.88071 3.5 6.5C3.5 5.11929 4.61929 4 6 4C7.38071 4 8.5 5.11929 8.5 6.5Z" />
      <path d="M15.5 3.5C15.5 4.88071 14.3807 6 13 6C11.6193 6 10.5 4.88071 10.5 3.5C10.5 2.11929 11.6193 1 13 1C14.3807 1 15.5 2.11929 15.5 3.5Z" />
      <path d="M21 7.5C21 8.88071 19.8807 10 18.5 10C17.1193 10 16 8.88071 16 7.5C16 6.11929 17.1193 5 18.5 5C19.8807 5 21 6.11929 21 7.5Z" />
      <path d="M12.5 23C16.6421 23 20 19.6421 20 15.5C20 12.5 17.5 10 14.5 10C13.5 10 12.5 10.5 12.5 10.5C12.5 10.5 11.5 10 10.5 10C7.5 10 5 12.5 5 15.5C5 19.6421 8.35786 23 12.5 23Z" />
    </svg>
  </div>
  <div class="bg-paw paw-right" aria-hidden="true">
  </div>

  <div class="container">
    <header class="section-header">
      <h2 id="visit-us-title" class="section-title">{VISIT_US_CONTENT.title}</h2>
      <div class="title-underline"></div>
    </header>

    <div class="locations-grid" role="list">
      {VISIT_US_CONTENT.branches.map((branch) => (
        <article class="location-card" role="listitem">
          <div class="branch-image-wrapper">
            <img
              src={branch.mapImage}
              alt={branch.name}
              class="branch-photo-img"
            />
            <div class="branch-badge">Location</div>
          </div>

          <div class="branch-content">
            <h3 class="branch-name">{branch.name}</h3>
            <p class="branch-address">{branch.address}</p>
            
            <div class="branch-meta">
              <div class="meta-item">
                <span class="meta-label">Phone:</span>
                <span class="meta-value">{branch.phone}</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Hours:</span>
                <span class="meta-value">{branch.hours}</span>
              </div>
            </div>

            <a href={branch.facebookLink} target="_blank" rel="noopener" class="facebook-link">
              <span class="facebook-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path fill="currentColor" d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073c0 6.017 4.388 11.005 10.125 11.927v-8.437H7.078v-3.49h3.047V9.412c0-3.017 1.792-4.686 4.533-4.686 1.313 0 2.686.236 2.686.236v2.962h-1.514c-1.491 0-1.956.931-1.956 1.887v2.262h3.328l-.532 3.49h-2.796V24C19.612 23.078 24 18.09 24 12.073z"/>
                </svg>
              </span>
              <span>{branch.facebookText}</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  :root {
    --color-bg-cream: #ede4c5;
    --color-text-green: #0a441e;
    --color-text-gold: #bb9313;
    --color-paw-print: rgba(224, 214, 184, 0.6);
    --card-shadow: 0 12px 40px rgba(10, 68, 30, 0.12);
  }

  .visit-us-section {
    position: relative;
    background-color: var(--color-bg-cream);
    padding: 6rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bg-paw {
    position: absolute;
    color: var(--color-paw-print);
    z-index: 1;
    pointer-events: none;
  }

  .bg-paw svg {
    width: 100%;
    height: 100%;
  }

  .paw-left {
    bottom: -5%;
    left: -5%;
    width: 25vw;
    transform: rotate(-15deg);
  }

  .paw-right {
    top: -5%;
    right: -5%;
    width: 20vw;
    transform: rotate(15deg);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-text-green);
    margin: 0;
  }

  .title-underline {
    width: 80px;
    height: 4px;
    background: var(--color-text-gold);
    margin: 1rem auto 0;
    border-radius: 2px;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 900px) {
    .locations-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.25rem;
    }
  }

  .location-card {
    background: #ffffff;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
    box-shadow: var(--card-shadow);
    border: 1px solid rgba(187, 147, 19, 0.1);
    height: 100%;
  }

  .location-card:hover {
    transform: translateY(-8px);
  }

  .branch-image-wrapper {
    position: relative;
    padding: 1rem;
  }

  .branch-photo-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }

  .branch-badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: var(--color-text-gold);
    color: #ffffff;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .branch-content {
    padding: 0.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .branch-name {
    font-family: 'Calistoga', serif;
    color: var(--color-text-green);
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
  }

  .branch-address {
    color: var(--color-text-green);
    opacity: 0.8;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 1.5rem 0;
    min-height: 3em;
    white-space: pre-line;
  }

  .branch-meta {
    border-top: 1px dashed rgba(10, 68, 30, 0.15);
    padding-top: 1.25rem;
    margin-bottom: 2rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    gap: 1rem;
  }

  .meta-label {
    font-weight: 700;
    color: var(--color-text-gold);
  }

  .meta-value {
    color: var(--color-text-green);
    text-align: right;
  }

  .facebook-link {
    margin-top: auto;
    background-color: var(--color-text-green);
    color: #ffffff;
    text-decoration: none;
    padding: 1rem;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .facebook-link:hover {
    background-color: var(--color-text-gold);
    box-shadow: 0 4px 15px rgba(187, 147, 19, 0.4);
  }

  .facebook-link:focus-visible {
    outline: 3px solid var(--color-text-gold);
    outline-offset: 3px;
  }

  .facebook-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  .facebook-icon svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .visit-us-section {
      padding: 4rem 1rem;
    }
    .location-card {
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .bg-paw {
      display: none;
    }
  }
</style>
