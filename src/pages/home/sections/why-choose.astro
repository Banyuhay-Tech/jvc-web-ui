---
import { WHY_CHOOSE_CONTENT } from '../../../data/why-choose-data';
import { WhyChooseIcon } from '../../../components/ui/WhyChooseIcon';
---

<section
  id="why-choose"
  class="why-choose-section"
  style={`background-image: linear-gradient(rgba(10, 68, 30, 0.4), rgba(10, 68, 30, 0.4)), url(${WHY_CHOOSE_CONTENT.bgImage});`}
  aria-labelledby="why-choose-title"
>
  <div class="container">
    <div class="header-group">
      <span class="subtitle">Quality You Can Trust</span>
      <h2 id="why-choose-title" class="section-title">{WHY_CHOOSE_CONTENT.title}</h2>
      <div class="title-accent"></div>
    </div>

    <!-- Features Grid -->
    <div class="features-grid">
      {WHY_CHOOSE_CONTENT.features.map((feature) => (
        <div class="feature-item">
          <div class="glass-overlay" aria-hidden="true"></div>
          <div class="card-inner">
            <div class="icon-wrapper">
              <WhyChooseIcon name={feature.iconName} size={56} />
            </div>
            <p class="feature-text">{feature.text}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer Text -->
    <h3 class="footer-text">{WHY_CHOOSE_CONTENT.footerText}</h3>
  </div>
</section>

<style>
  :root {
    --color-gold: #d4af37;
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-border: rgba(255, 255, 255, 0.15);
    --transition-smooth: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .why-choose-section {
    position: relative;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    padding: 8rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    color: #ffffff;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  .header-group {
    text-align: center;
    margin-bottom: 5rem;
  }

  .subtitle {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.8rem;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    margin: 0;
    text-shadow: 0 0 30px rgba(0, 0, 0, 0.3);
  }

  .title-accent {
    width: 40px;
    height: 2px;
    background: var(--color-gold);
    margin: 1.5rem auto 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    margin-bottom: 6rem;
  }

  .feature-item {
    position: relative;
    padding: 3rem 2rem;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
    transition: var(--transition-smooth);
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .feature-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-gold);
    transform: scaleX(0);
    transition: var(--transition-smooth);
  }

  .feature-item:hover {
    transform: translateY(-10px);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .feature-item:hover::before {
    transform: scaleX(1);
  }

  .glass-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, rgba(212, 175, 55, 0.12), transparent 55%);
    opacity: 1;
    pointer-events: none;
  }

  .card-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .icon-wrapper {
    color: var(--color-gold);
    filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.3));
  }

  .feature-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.05rem;
    line-height: 1.6;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    text-align: center;
  }

  .footer-text {
    font-family: 'Calistoga', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    max-width: 800px;
    margin: 0 auto;
    color: #ffffff;
    text-align: center;
  }

  @media (max-width: 600px) {
    .why-choose-section {
      padding: 5rem 1rem;
      background-attachment: scroll;
    }
  }
</style>
