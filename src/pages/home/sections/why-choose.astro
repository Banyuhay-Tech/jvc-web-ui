---
import { WHY_CHOOSE_CONTENT } from '../../../data/why-choose-data';
import { WhyChooseIcon } from '../../../components/ui/WhyChooseIcon';
---

<section
  class="why-choose-section"
  style={`background-image: url(${WHY_CHOOSE_CONTENT.bgImage});`}
  aria-labelledby="why-choose-title"
>
  <div class="container">
    <!-- Title with Gold Outline Effect -->
    <h2 id="why-choose-title" class="section-title">{WHY_CHOOSE_CONTENT.title}</h2>

    <!-- Features Grid -->
    <div class="features-grid">
      {WHY_CHOOSE_CONTENT.features.map((feature) => (
        <div class="feature-item">
          <div class="feature-item-header">
            <div class="icon-wrapper">
              <WhyChooseIcon name={feature.iconName} size={72} />
            </div>
          </div>
          <p class="feature-text">{feature.text}</p>
        </div>
      ))}
    </div>

    <!-- Footer Text -->
    <h3 class="footer-text">{WHY_CHOOSE_CONTENT.footerText}</h3>
  </div>
</section>

<style>
  /* COLORS & TOKENS */
  :root {
    --color-text-white: #ffffff;
    --color-gold-outline: #bb9313;
    --color-card-green: rgba(10, 68, 30, 0.75);
  }

  .why-choose-section {
    position: relative;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 5rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    color: var(--color-text-white);
    text-align: center;
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* TITLE STYLING - text-shadow for thick outer stroke */
  .section-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 800;
    margin: 0 0 4rem 0;
    line-height: 1.3;
    letter-spacing: 0.02em;
    white-space: nowrap;
    text-shadow:
      -2px -2px 0 var(--color-gold-outline),
      2px -2px 0 var(--color-gold-outline),
      -2px 2px 0 var(--color-gold-outline),
      2px 2px 0 var(--color-gold-outline),
      0px 4px 10px rgba(0, 0, 0, 0.4);
  }

  /* FEATURES GRID */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
    text-align: center;
  }

  @media (min-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-card-green);
    padding: 1.5rem 1.25rem;
    border-radius: 24px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    aspect-ratio: 1;
    min-height: 0;
  }

  .feature-item:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
  }

  .feature-item-header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .icon-wrapper {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
    color: var(--color-text-white);
  }

  .feature-text {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    margin: 0;
    text-align: center;
    color: rgba(255, 255, 255, 0.95);
  }

  @media (min-width: 900px) {
    .feature-text {
      font-size: 0.9rem;
    }
  }

  /* FOOTER TEXT */
  .footer-text {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.35;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 899px) {
    .feature-item {
      aspect-ratio: auto;
      padding: 1.5rem 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .why-choose-section {
      padding: 4rem 1rem;
    }

    .feature-item {
      border-radius: 20px;
    }
  }
</style>
